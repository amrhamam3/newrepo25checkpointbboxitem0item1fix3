    <!-- اتغيّرت عشان تتطابق مع خلفية شاشة الترحيب (Splash) — كانت رمادي غامق (#15171C)
         بقت كحلي/أسود قريب جدًا من لون الـ Splash نفسه (#020510) عشان التطبيق كله
         ياخد نفس الروح البصرية. -->
    <color name="background_dark">#05070c</color>
